{
  "name": "@aidrift/cli",
  "version": "0.1.2",
  "description": "drift CLI — watch your AI coding sessions, detect drift, checkpoint safely.",
  "type": "module",
  "bin": {
    "drift": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "ai",
    "drift",
    "claude",
    "claude-code",
    "codex",
    "cli",
    "observability",
    "quality"
  ],
  "author": {
    "name": "GenioHub",
    "email": "support@geniohub.com",
    "url": "https://drift.geniohub.com"
  },
  "license": "MIT",
  "homepage": "https://drift.geniohub.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geniohub/aidrift-cli.git"
  },
  "bugs": {
    "url": "https://github.com/geniohub/aidrift-cli/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.1.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
